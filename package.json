{
  "name": "cobranca-atendimentos",
  "version": "1.0.0",
  "description": "Sistema de Cobrança de Atendimentos",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch server.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node server.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
