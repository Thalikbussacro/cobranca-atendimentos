{
  "name": "cobranca-atendimentos",
  "version": "1.0.0",
  "description": "Sistema de Cobrança de Atendimentos - Monolito",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon src/server.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client && npm run copy:client",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "copy:client": "cpy client/dist/** dist/public --parents",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mssql": "^12.2.0",
    "nodemailer": "^7.0.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^7.0.9",
    "concurrently": "^9.2.1",
    "cpx2": "^8.0.0",
    "cpy-cli": "^7.0.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
